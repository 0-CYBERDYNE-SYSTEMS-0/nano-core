# FFT_nano environment configuration (NO SECRETS)
#
# This file is a template. Copy to .env and fill in your own values.
# The host process reads .env and passes an allowlisted subset into the agent
# container (see src/container-runner.ts).

# ----------------------
# Channels
# ----------------------

# Runtime profile:
# - core (default): generic OpenClaw-style behavior
# - farm: enables farm bridge/state/runtime paths
# FFT_PROFILE=core
# Optional hard override for farm feature paths (1/0). Defaults from FFT_PROFILE.
# FEATURE_FARM=0

# WhatsApp: enabled by default when set to 1.
# If using Telegram only (recommended for dev): set WHATSAPP_ENABLED=0
WHATSAPP_ENABLED=0

# Telegram: enable by setting a bot token
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# Optional: make a specific Telegram chat the main/admin channel
# TELEGRAM_MAIN_CHAT_ID=123456789

# Optional: allow claiming the main chat by DMing /main <secret>
# TELEGRAM_ADMIN_SECRET=change-me

# Optional: max size (MB) for inbound Telegram media persisted to groups/<group>/inbox/telegram
# TELEGRAM_MEDIA_MAX_MB=20

# Optional: assistant mention name used for trigger matching in non-main chats
# ASSISTANT_NAME=OpenClaw

# Optional: additional trigger aliases (comma-separated), e.g. supports @F-15 and @OpenClaw
# ASSISTANT_ALIASES=F-15,OpenClaw

# Optional: main/admin workspace path mounted as /workspace/group in main chat runs
# FFT_NANO_MAIN_WORKSPACE_DIR=~/nano
# Optional: enforce main-chat bootstrap interview until onboarding completes
# FFT_NANO_WORKSPACE_ENFORCE_BOOTSTRAP_GATE=1
# Optional: retroactively enforce gate for existing installs with legacy pending BOOTSTRAP.md
# FFT_NANO_WORKSPACE_ENFORCE_BOOTSTRAP_GATE_EXISTING=0

# Optional: heartbeat cadence for periodic main-session checks (e.g. 15m, 30m, 1h; 0m disables)
# FFT_NANO_HEARTBEAT_EVERY=30m
# Optional: heartbeat prompt override
# FFT_NANO_HEARTBEAT_PROMPT=Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK.
# Optional: max characters allowed after HEARTBEAT_OK before treating response as actionable
# FFT_NANO_HEARTBEAT_ACK_MAX_CHARS=300
# Optional: only run heartbeat during active hours (local time): HH:MM-HH:MM or Mon-Fri@HH:MM-HH:MM
# FFT_NANO_HEARTBEAT_ACTIVE_HOURS=09:00-18:00

# Optional: scheduler mode
# - v2 (default): timer-based scheduler with v2 task fields/backoff
# - legacy: fixed polling scheduler loop
# FFT_NANO_SCHEDULER_MODE=v2

# Optional: OpenClaw-style attached TUI gateway settings
# FFT_NANO_TUI_ENABLED=1
# FFT_NANO_TUI_HOST=127.0.0.1
# FFT_NANO_TUI_PORT=28989
# FFT_NANO_TUI_AUTH_TOKEN=

# Optional: FFT CONTROL CENTER web dashboard settings
# FFT_NANO_WEB_ENABLED=1
# FFT_NANO_WEB_ACCESS_MODE=localhost   # localhost|lan|remote
# FFT_NANO_WEB_HOST=127.0.0.1
# FFT_NANO_WEB_PORT=28990
# FFT_NANO_WEB_AUTH_TOKEN=

# ----------------------
# Farm bridge / dashboard integration
# ----------------------

# Farm mode:
# - demo: quick showcase using simulated telemetry
# - production: real-device onboarding with mapping + validation gate
# FARM_MODE=demo

# Enable farm-state collector + farm action gateway
# FARM_STATE_ENABLED=true

# Home Assistant endpoint + token for farm polling/actions
# HA_URL=http://localhost:8123
# Optional fallback list (comma-separated). Tried in order for reachability/failover.
# HA_URL_CANDIDATES=http://localhost:8123,http://192.168.64.1:8123
# HA_TOKEN=your-long-lived-ha-token

# Path to FFT dashboard repo (mounted for main chat dashboard operations)
# FFT_DASHBOARD_REPO_PATH=/absolute/path/to/FFT_demo_dash

# Companion dashboard template source and pin (used by scripts/farm-bootstrap.sh)
# FFT_DASHBOARD_REPO_URL=https://github.com/0-CYBERDYNE-SYSTEMS-0/FFT_demo_dash.git
# FFT_DASHBOARD_REPO_REF=dee8fc890845825a4e77c189ef6b6ab64676baed

# Farm profile mapping file (written by scripts/farm-onboarding.sh)
# FARM_PROFILE_PATH=/absolute/path/to/FFT_nano/data/farm-profile.json

# ----------------------
# Container runtime
# ----------------------

# auto (default): Docker if available; no implicit host fallback
# CONTAINER_RUNTIME=auto

# Optional unisolated host runtime (advanced/debug only, explicit opt-in required)
# CONTAINER_RUNTIME=host
# FFT_NANO_ALLOW_HOST_RUNTIME=1
# FFT_NANO_ALLOW_HOST_RUNTIME_IN_PROD=0

# Agent image (built by ./container/build.sh or ./container/build-docker.sh)
# CONTAINER_IMAGE=fft-nano-agent:latest

# ----------------------
# Pi runtime (LLM provider)
# ----------------------

# Option A: OpenAI
# FFT_NANO_RUNTIME_PROVIDER_PRESET=openai
# PI_API=openai
# PI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=...
# Optional OpenAI-compatible endpoint for local inference:
# OPENAI_BASE_URL=http://localhost:11434/v1

# Option B: Anthropic API key
# PI_API=anthropic
# PI_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_API_KEY=...

# Option C: Gemini
# PI_API=gemini
# PI_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=...

# Option D: OpenRouter
# PI_API=openrouter
# PI_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_API_KEY=...

# Option E: OpenCode Go
# FFT_NANO_RUNTIME_PROVIDER_PRESET=opencode-go
# PI_API=opencode-go
# PI_MODEL=deepseek-v4-pro
# OPENCODE_API_KEY=...
# Optional fallback for manual/provider override flows:
# PI_API_KEY=...
# Other OpenCode Go models include:
#   PI_MODEL=deepseek-v4-flash
#   PI_MODEL=glm-5
#   PI_MODEL=glm-5.1
#   PI_MODEL=kimi-k2.5
#   PI_MODEL=mimo-v2-pro
#   PI_MODEL=mimo-v2-omni
#   PI_MODEL=minimax-m2.5
#   PI_MODEL=minimax-m2.7
#   PI_MODEL=qwen3.5-plus
#   PI_MODEL=qwen3.6-plus

# Option F: Ollama (local — uses the custom ollama provider)
# FFT_NANO_RUNTIME_PROVIDER_PRESET=ollama
# PI_API=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# PI_BASE_URL=http://localhost:11434/v1
# PI_API_KEY=ollama
# Available models:
#   PI_MODEL=qwen3.5:4b
#   PI_MODEL=qwen3.5:2b
#   PI_MODEL=qwen3.5:0.8b
#   PI_MODEL=sam860/lucy:1.7b
#   PI_MODEL=deepscaler:latest
#   PI_MODEL=granite3.1-dense:2b
#   PI_MODEL=granite3.1-moe:latest
#   PI_MODEL=granite3.1-moe:1b
#   PI_MODEL=llama3.2:1b
#   PI_MODEL=deepseek-r1:1.5b

# Option G: LM Studio (local — OpenAI-compatible server)
# FFT_NANO_RUNTIME_PROVIDER_PRESET=lm-studio
# PI_API=openai
# PI_MODEL=qwen2.5-coder-7b-instruct
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# PI_BASE_URL=http://127.0.0.1:1234/v1
# PI_API_KEY=lm-studio

# ----------------------
# Debug
# ----------------------
# LOG_LEVEL=debug
# FFT_NANO_DRY_RUN=1

# ----------------------
# Memory retrieval gate
# ----------------------
# Enable lexical memory retrieval gate (recommended)
# MEMORY_RETRIEVAL_GATE_ENABLED=1
# Max number of memory snippets to inject per run
# MEMORY_TOP_K=8
# Hard character budget for injected memory context
# MEMORY_CONTEXT_CHAR_BUDGET=6000
