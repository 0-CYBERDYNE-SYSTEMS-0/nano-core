{
  "name": "ff-nano",
  "version": "0.1.0",
  "description": "Agnostic AI agent runtime with capability profiles",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0-CYBERDYNE-SYSTEMS-0/nano-core.git"
  },
  "bugs": {
    "url": "https://github.com/0-CYBERDYNE-SYSTEMS-0/nano-core/issues"
  },
  "homepage": "https://github.com/0-CYBERDYNE-SYSTEMS-0/nano-core#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ff-nano": "./bin/fft.js",
    "fft": "./bin/fft.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test $(find tests container/agent-runner/src -type f -name '*.test.ts' | tr '\\n' ' ')",
    "ff-nano": "node ./bin/fft.js",
    "fft": "node ./bin/fft.js",
    "profile": "tsx src/profile-cli.ts",
    "profile:install": "tsx src/profile-cli.ts install",
    "profile:list": "tsx src/profile-cli.ts list",
    "profile:activate": "tsx src/profile-cli.ts activate",
    "profile:switch": "tsx src/profile-cli.ts switch",
    "profile:remove": "tsx src/profile-cli.ts remove",
    "web:install": "npm --prefix web/control-center ci",
    "web:build": "npm --prefix web/control-center run build",
    "web:dev": "npm --prefix web/control-center run dev",
    "tui": "node dist/tui/start.js",
    "tui:dev": "tsx src/tui/start.ts",
    "tui:client": "node dist/tui/client.js",
    "tui:client:dev": "tsx src/tui/client.ts",
    "onboard": "tsx src/onboard-cli.ts",
    "onboard:full": "bash scripts/onboard-all.sh",
    "backup:state": "bash scripts/backup-state.sh",
    "restore:state": "bash scripts/restore-state.sh",
    "auth": "tsx src/whatsapp-auth.ts",
    "doctor": "tsx src/doctor.ts",
    "farm:doctor": "bash scripts/farm-doctor.sh",
    "validate:skills": "tsx scripts/validate-pi-skills.ts",
    "secret-scan": "bash scripts/secret-scan.sh",
    "pack-check": "bash scripts/check-pack-contents.sh",
    "release-check": "bash scripts/release-check.sh",
    "release:sha256": "bash scripts/release/generate-sha256s.sh",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@mariozechner/pi-tui": "^0.53.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.8.1",
    "chalk": "^5.6.2",
    "cron-parser": "^5.5.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.13",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
