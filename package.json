{
  "name": "nano-core",
  "version": "0.4.0",
  "description": "nano-core: industry-agnostic AI coworker runtime. Receives messages, runs an agent subprocess, persists state. No subscriptions. MIT licensed.",
  "keywords": [
    "autonomous-agents",
    "ai-agents",
    "llm",
    "llm-agents",
    "nodejs",
    "typescript",
    "telegram-bot",
    "whatsapp-bot",
    "raspberry-pi",
    "open-source",
    "automation",
    "persistent-memory",
    "local-first-ai"
  ],
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0-CYBERDYNE-SYSTEMS-0/nano-core.git"
  },
  "bugs": {
    "url": "https://github.com/0-CYBERDYNE-SYSTEMS-0/nano-core/issues"
  },
  "homepage": "https://github.com/0-CYBERDYNE-SYSTEMS-0/nano-core#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nano": "./bin/nano.js",
    "nano-core": "./bin/nano.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test $(find tests -type f -name '*.test.ts' | tr '\\n' ' ')",
    "web:install": "npm --prefix web/control-center ci",
    "web:build": "npm --prefix web/control-center run build",
    "web:dev": "npm --prefix web/control-center run dev",
    "tui": "node dist/tui/start.js",
    "tui:dev": "tsx src/tui/start.ts",
    "tui:client": "node dist/tui/client.js",
    "tui:client:dev": "tsx src/tui/client.ts",
    "onboard": "tsx src/onboard-cli.ts",
    "onboard:full": "bash scripts/onboard-all.sh",
    "backup:state": "bash scripts/backup-state.sh",
    "restore:state": "bash scripts/restore-state.sh",
    "auth": "tsx src/whatsapp-auth.ts",
    "doctor": "tsx src/doctor.ts",
    "curator": "tsx src/skill-curator-cli.ts",
    "skill-manager": "tsx src/skill-manager-cli.ts",
    "validate:skills": "tsx scripts/validate-pi-skills.ts",
    "check:core-surface": "node scripts/sync-nano-core.mjs scan --target . --config config/nano-core-sync.json",
    "secret-scan": "bash scripts/secret-scan.sh",
    "pack-check": "bash scripts/check-pack-contents.sh",
    "release-check": "bash scripts/release-check.sh",
    "release:sha256": "bash scripts/release/generate-sha256s.sh",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.73.1",
    "@mariozechner/pi-tui": "^0.53.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "cron-parser": "^5.5.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.13",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
